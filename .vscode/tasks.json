{
  "tasks": [
    {
      "label": "Create bin folder",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-Command",
        "New-Item -ItemType Directory -Force -Path ${workspaceFolder}\\bin | Out-Null"
      ],
      "problemMatcher": [],
      "detail": "Ensure bin folder exists for build outputs"
    },
    {
      "type": "cppbuild",
      "label": "C/C++: cl.exe build active file",
      "command": "cl.exe",
      "dependsOn": "Create bin folder",
      "args": [
        "/Zi",
        "/EHsc",
        "/nologo",
        "/Fe${workspaceFolder}\\bin\\${fileBasenameNoExtension}.exe",
        "/Fo${workspaceFolder}\\bin\\${fileBasenameNoExtension}.obj",
        "/Fd${workspaceFolder}\\bin\\${fileBasenameNoExtension}.pdb",
        "${file}"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": [
        "$msCompile"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "Task generated by Debugger. Outputs go to bin\\"
    },
    {
      "label": "Clean bin",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-Command",
        "Remove-Item -Path ${workspaceFolder}\\bin\\*.exe -Force -ErrorAction SilentlyContinue"
      ],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "detail": "Removes executables from the bin folder"
    }
  ],
  "version": "2.0.0"
}